AttackTarget CPE=cpe:2.3:a:eprosima:fast_dds:2.1.1 synonyms=("ros-foxy-fastrtps") CWE=CWE-20.0 cweNotes="Improper Input Validation" note="Generated for search by cpe for keyword: cpe:2.3:a:eprosima:fast_dds:2.1.1" {
OR {
AttackStep CVE202430258 description="FastDDS is a C++ implementation of the DDS (Data Distribution Service) standard of the OMG (Object Management Group). Prior to versions 2.14.1, 2.13.5, 2.10.4, and 2.6.8, when a publisher serves a malformed `RTPS` packet, the subscriber crashes when creating `pthread`. This can remotely crash any Fast-DDS process, potentially leading to a DOS attack. Versions 2.14.1, 2.13.5, 2.10.4, and 2.6.8 contain a patch for the issue.
" CVE=CVE-2024-30258 CVSS=CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:L/A:H BaseScore=8.2 ImpactScore=4.2 ExploitabilityScore=3.9
} 
}
