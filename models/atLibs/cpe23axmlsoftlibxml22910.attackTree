AttackTarget CPE=cpe:2.3:a:xmlsoft:libxml2:2.9.10 synonyms=("libxml2") CWE=CWE-415 cweNotes="Double Free" note="Generated for search by cpe for keyword: cpe:2.3:a:xmlsoft:libxml2:2.9.10" {
OR {
AttackStep CVE202240304 description="An issue was discovered in libxml2 before 2.10.3. Certain invalid XML entity definitions can corrupt a hash table key, potentially leading to subsequent logic errors. In one case, a double-free can be provoked." CVE=CVE-2022-40304 CVSS=CVSS:3.1/AV:L/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:H BaseScore=7.8 ImpactScore=5.9 ExploitabilityScore=1.8,
AttackStep CVE202329469 description="An issue was discovered in libxml2 before 2.10.4. When hashing empty dict strings in a crafted XML document, xmlDictComputeFastKey in dict.c can produce non-deterministic values, leading to various logic and memory errors, such as a double free. This behavior occurs because there is an attempt to use the first byte of an empty string, and any value is possible (not solely the '\0' value)." CVE=CVE-2023-29469 CVSS=CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:H BaseScore=6.5 ImpactScore=3.6 ExploitabilityScore=2.8
} 
}
