AttackTarget CPE=cpe:2.3:a:xmlsoft:libxml2:2.9.10 synonyms=("libxml2") CWE=CWE-190 cweNotes="Integer Overflow or Wraparound" note="Generated for search by cpe for keyword: cpe:2.3:a:xmlsoft:libxml2:2.9.10" {
OR {
AttackStep CVE202229824 description="In libxml2 before 2.9.14, several buffer handling functions in buf.c (xmlBuf*) and tree.c (xmlBuffer*) don't check for integer overflows. This can result in out-of-bounds memory writes. Exploitation requires a victim to open a crafted, multi-gigabyte XML file. Other software using libxml2's buffer functions, for example libxslt through 1.1.35, is affected as well." CVE=CVE-2022-29824 CVSS=CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:H BaseScore=6.5 ImpactScore=3.6 ExploitabilityScore=2.8,
AttackStep CVE202240303 description="An issue was discovered in libxml2 before 2.10.3. When parsing a multi-gigabyte XML document with the XML_PARSE_HUGE parser option enabled, several integer counters can overflow. This results in an attempt to access an array at a negative 2GB offset, typically leading to a segmentation fault." CVE=CVE-2022-40303 CVSS=CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H BaseScore=7.5 ImpactScore=3.6 ExploitabilityScore=3.9
} 
}
